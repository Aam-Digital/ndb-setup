DOMAIN=aam-digital.app
PREFIX=c-
BWS_ACCESS_TOKEN=
BACKUP_DIR=
BACKUP_PASSPHRASE=

# Environment-specific service endpoints.
# These must match the cluster this server is connected to:
#
#   Environment  KEYCLOAK_HOST                  CARBONE_HOST
#   -----------  -----------------------------  --------------------------------
#   Staging      keycloak.aam-digital.net        pdf.dev-cluster.aam-digital.net
#   Production   keycloak.aam-digital.com        pdf.aam-digital.app
#
# KEYCLOAK_HOST is normally fetched via BWS_ACCESS_TOKEN; set it here only to
# override (e.g. when running scripts without BWS access).
CARBONE_HOST=
# KEYCLOAK_HOST=

# Contact email for the webmaster/operator of this server, used e.g. as the
# Nominatim API email (required by OSM usage policy).
WEBMASTER_EMAIL=webmaster@example.com